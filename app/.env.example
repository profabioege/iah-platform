# Formulário de demonstração da Landing (Resend)
# RESEND_API_KEY: chave da conta Resend (obrigatória para o envio funcionar).
RESEND_API_KEY=
# Destino dos leads (padrão: contato@iaheducacional.com.br).
CONTACT_TO_EMAIL=contato@iaheducacional.com.br
# Remetente verificado no Resend. Enquanto o domínio não é verificado,
# use o remetente de teste do Resend: "IAH Educacional <onboarding@resend.dev>".
CONTACT_FROM_EMAIL=IAH Educacional <onboarding@resend.dev>
# Número do WhatsApp (só dígitos, com DDI/DDD, ex.: 5511999998888).
# O botão de WhatsApp só aparece quando este valor está definido.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Supabase (ainda não configurado)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (integração futura)
# OPENAI_API_KEY=

# Google Classroom / Google Agenda (integração futura)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Canva (integração futura)
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
