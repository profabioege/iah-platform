# ============================================================
# IAH Educacional — variáveis de ambiente
# Nenhuma é obrigatória para o site subir: cada ausência apenas
# desliga a funcionalidade correspondente. Segredos existem SÓ em
# .env.local (gitignored) e no painel da Vercel — nunca em código.
# ============================================================

# ------------------------------------------------------------
# Modo REAL — persistência e autenticação (M22) — docs/PERSISTENCE.md
# e docs/AUTHENTICATION.md. As TRÊS primeiras (AUTH_SECRET +
# NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY) precisam estar
# TODAS definidas para o modo real ativar — configuração parcial nunca
# ativa o banco nem derruba a Plataforma: fica em erro explícito
# (docs/PERSISTENCE.md, "Critérios de ativação"). Sem nenhuma delas, a
# Plataforma opera em modo demonstração (Institutional Workspace local
# simulado), exatamente como antes.
# ------------------------------------------------------------
# Segredo do Auth.js (gere com: npx auth secret  |ou|  openssl rand -base64 32).
AUTH_SECRET=
# URL do projeto Supabase.
NEXT_PUBLIC_SUPABASE_URL=
# Service role: usada SÓ no servidor (login por senha, leitura/escrita de
# toda entidade institucional). Ignora RLS — jamais expor com prefixo
# NEXT_PUBLIC_, jamais importar em componente de cliente (D-041).
SUPABASE_SERVICE_ROLE_KEY=
# Chave anônima — não usada pelo núcleo institucional (acesso é sempre
# via service role, server-side); mantida só para módulos que ainda
# checam isDatabaseConfigured() (Knowledge/Curriculum, stubs).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Senha das contas de demonstração inseridas por app/db/seed/seed-demo.mjs
# — nunca em código, só nesta variável (local ou na execução do seed).
IAH_DEMO_PASSWORD=

# ------------------------------------------------------------
# Login com Google (opcional, além do e-mail+senha acima) — docs/AUTHENTICATION.md
# ------------------------------------------------------------
# Credencial OAuth 2.0 do Google Cloud Console (aplicação Web).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Allowlist do login Google, separada por vírgula. FECHADA POR PADRÃO:
# sem esta lista, nenhum login por Google é aceito (login por senha não
# usa esta allowlist — o vínculo vem do cadastro em `profiles`).
AUTH_ALLOWED_EMAILS=
# Slug da Instituição (tabela institutions) à qual um professor logado
# por Google é associado no primeiro acesso — docs/SUPABASE.md.
AUTH_DEFAULT_INSTITUTION_SLUG=

# ------------------------------------------------------------
# Formulários da Landing (Resend)
# ------------------------------------------------------------
# Chave da conta Resend (obrigatória para o envio real funcionar).
RESEND_API_KEY=
# Destino dos leads (padrão: contato@iaheducacional.com.br).
CONTACT_TO_EMAIL=contato@iaheducacional.com.br
# Remetente verificado no Resend. Enquanto o domínio não é verificado,
# use o remetente de teste: "IAH Educacional <onboarding@resend.dev>".
CONTACT_FROM_EMAIL=IAH Educacional <onboarding@resend.dev>

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
# Número do WhatsApp (só dígitos, com DDI/DDD, ex.: 5511999998888).
# O botão de WhatsApp só aparece quando este valor está definido.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ------------------------------------------------------------
# Mentor IAH (opcional)
# ------------------------------------------------------------
# Ativa o apoio socrático local dentro de Missions publicadas.
NEXT_PUBLIC_FEATURE_MENTOR_IAH=false

# ------------------------------------------------------------
# Integrações futuras (ainda não usadas)
# ------------------------------------------------------------
# OPENAI_API_KEY=
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
