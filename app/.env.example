# ============================================================
# IAH Educacional — variáveis de ambiente
# Nenhuma é obrigatória para o site subir: cada ausência apenas
# desliga a funcionalidade correspondente. Segredos existem SÓ em
# .env.local (gitignored) e no painel da Vercel — nunca em código.
# ============================================================

# ------------------------------------------------------------
# Autenticação (Auth.js + Google) — docs/AUTHENTICATION.md
# Sem as 3 primeiras, a Plataforma opera em modo demonstração
# (acesso direto, sem login), exatamente como antes.
# ------------------------------------------------------------
# Credencial OAuth 2.0 do Google Cloud Console (aplicação Web).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Segredo do Auth.js (gere com: npx auth secret  |ou|  openssl rand -base64 32).
AUTH_SECRET=
# Allowlist de login, separada por vírgula. FECHADA POR PADRÃO:
# sem esta lista, nenhum login é aceito.
AUTH_ALLOWED_EMAILS=
# Slug da Instituição (tabela institutions) à qual o professor é
# associado no primeiro login. A linha é inserida manualmente — docs/SUPABASE.md.
AUTH_DEFAULT_INSTITUTION_SLUG=

# ------------------------------------------------------------
# Banco de dados (Supabase/PostgreSQL) — docs/SUPABASE.md e docs/PERSISTENCE.md
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SÓ servidor (provisionamento de identidade). Ignora RLS —
# jamais expor com prefixo NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Formulários da Landing (Resend)
# ------------------------------------------------------------
# Chave da conta Resend (obrigatória para o envio real funcionar).
RESEND_API_KEY=
# Destino dos leads (padrão: contato@iaheducacional.com.br).
CONTACT_TO_EMAIL=contato@iaheducacional.com.br
# Remetente verificado no Resend. Enquanto o domínio não é verificado,
# use o remetente de teste: "IAH Educacional <onboarding@resend.dev>".
CONTACT_FROM_EMAIL=IAH Educacional <onboarding@resend.dev>

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
# Número do WhatsApp (só dígitos, com DDI/DDD, ex.: 5511999998888).
# O botão de WhatsApp só aparece quando este valor está definido.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ------------------------------------------------------------
# Integrações futuras (ainda não usadas)
# ------------------------------------------------------------
# OPENAI_API_KEY=
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
